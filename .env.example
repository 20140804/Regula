# .env.example
# ===== 基础配置 =====
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///./regula_enterprise.db
DEBUG=true
PORT=8000

# ===== API 密钥 =====
API_KEYS=regula_api_2024_secure_key

# ===== 文件限制 =====
MAX_FILE_SIZE_MB=10

# ===== JWT 配置 =====
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
JWT_REFRESH_EXPIRE_DAYS=30

# ===== 限流配置 =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_PATH=logs/regula.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=10

# ===== Webhook =====
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT=5
WEBHOOK_URLS=

# ===== 支付配置（Lemon Squeezy）=====
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ===== 产品 Variant IDs =====
PRODUCT_PRO_VARIANT_ID=123456
PRODUCT_PRO_MAX_VARIANT_ID=123457
PRODUCT_ENTERPRISE_VARIANT_ID=123458

# ===== 邮件配置 =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Regula <noreply@regula.com>

# ===== 私钥（用于生成激活码）=====
PRIVATE_KEY_PRO=-----BEGIN PRIVATE KEY-----\n你的Pro私钥\n-----END PRIVATE KEY-----
PRIVATE_KEY_PROMAX=-----BEGIN PRIVATE KEY-----\n你的Pro Max私钥\n-----END PRIVATE KEY-----